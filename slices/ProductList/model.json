{
  "id": "product_list",
  "type": "SharedSlice",
  "name": "ProductList",
  "description": "Product listing in carousel or grid layouts",
  "variations": [
    {
      "id": "default",
      "name": "Carousel 4 Cols",
      "docURL": "...",
      "version": "initial",
      "description": "Product carousel with 4-column basis",
      "imageUrl": "",
      "primary": {
        "tagline": {
          "type": "Text",
          "config": {
            "label": "Tagline",
            "placeholder": "Enter tagline"
          }
        },
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Heading",
            "single": "heading2",
            "placeholder": "Enter heading"
          }
        },
        "description": {
          "type": "StructuredText",
          "config": {
            "label": "Description",
            "single": "paragraph,strong,em,hyperlink",
            "placeholder": "Enter description"
          }
        },
        "view_all_link": {
          "type": "Link",
          "config": {
            "label": "View All Link",
            "allowText": true,
            "select": null
          }
        },
        "products": {
          "type": "Group",
          "config": {
            "label": "Products",
            "fields": {
              "product_reference": {
                "type": "Text",
                "config": {
                  "label": "Product Reference",
                  "placeholder": "Product ID (e.g., 1)"
                }
              }
            }
          }
        }
      },
