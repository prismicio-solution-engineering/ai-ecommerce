        "description": {
          "type": "StructuredText",
          "config": {
            "label": "Description",
            "single": "paragraph,strong,em,hyperlink",
            "placeholder": "Enter description"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Image"
          }
        },
        "image_left": {
          "type": "Boolean",
          "config": {
            "label": "Image on left"
          }
