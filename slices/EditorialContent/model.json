{
  "id": "editorial_content",
  "type": "SharedSlice",
  "name": "EditorialContent",
  "description": "Editorial content sections with rich text, images, and quotes",
  "variations": [
    {
      "id": "default",
      "name": "Default Rich Text",
      "docURL": "...",
      "version": "initial",
      "description": "Full-width rich text content block",
      "imageUrl": "",
      "primary": {
        "content": {
          "type": "StructuredText",
          "config": {
            "label": "Content",
            "multi": "paragraph,preformatted,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,list-item,o-list-item",
            "placeholder": "Enter content"
          }
        }
      },
      "items": {}
    },
    {
      "id": "twoColsTextAndImage",
      "name": "Two Cols Text and Image",
      "docURL": "...",
      "version": "initial",
      "description": "Two columns with rich text and image, switchable sides",
      "imageUrl": "",
      "primary": {
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Heading",
            "single": "heading2",
            "placeholder": "Enter heading"
          }
        },
        "content": {
          "type": "StructuredText",
          "config": {
            "label": "Content",
            "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
            "placeholder": "Enter content"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Image"
          }
        },
        "image_left": {
          "type": "Boolean",
          "config": {
            "label": "Image on left"
          }
        }
      },
      "items": {}
    },
    {
      "id": "twoColsWithFullSizeImage",
      "name": "Two Cols With Full Size Image",
      "docURL": "...",
      "version": "initial",
      "description": "Two columns with full-height image, optional buttons",
      "imageUrl": "",
      "primary": {
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Heading",
            "single": "heading1",
            "placeholder": "Enter heading"
          }
        },
        "description": {
          "type": "StructuredText",
          "config": {
            "label": "Description",
            "single": "paragraph,strong,em,hyperlink",
            "placeholder": "Enter description"
          }
        },
        "buttons": {
          "type": "Link",
          "config": {
            "label": "Buttons",
            "allowText": true,
            "repeat": true,
            "variants": [
              "Primary",
              "Secondary"
            ],
            "select": null
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Image"
          }
        },
        "image_left": {
          "type": "Boolean",
          "config": {
            "label": "Image on left"
          }
        }
      },
      "items": {}
    },
    {
      "id": "quote",
      "name": "Quote",
      "docURL": "...",
      "version": "initial",
      "description": "Blockquote with attribution",
      "imageUrl": "",
      "primary": {
        "quote": {
          "type": "StructuredText",
          "config": {
            "label": "Quote",
            "single": "paragraph,strong,em",
            "placeholder": "Enter quote"
          }
        },
        "author_name": {
          "type": "Text",
          "config": {
            "label": "Author Name",
            "placeholder": "Full name"
          }
        },
        "author_title": {
          "type": "Text",
          "config": {
            "label": "Author Title",
            "placeholder": "Job title, Company"
          }
        },
        "author_image": {
          "type": "Image",
          "config": {
            "label": "Author Image"
          }
        }
      },
      "items": {}
    },
    {
